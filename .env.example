# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kpai:kpai_secret@localhost:5432/kpai_db

# ── Security ──────────────────────────────────────────────────────
SECRET_KEY=supersecretkey_change_in_production_32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── ChromaDB ──────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Redis / Celery ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Bhashini API ─────────────────────────────────────────────────
# Get your key from: https://bhashini.gov.in/ulca/user/register
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_PIPELINE_ID=64392f96daac500b55c543cd

# ── Google Maps (for crime heatmap) ──────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── App Config ────────────────────────────────────────────────────
APP_ENV=development
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
LOG_LEVEL=INFO

# ── ML Model ─────────────────────────────────────────────────────
# Downloaded automatically on first run
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
